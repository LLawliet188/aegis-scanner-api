AEGIS_ENVIRONMENT=development
AEGIS_HOST=0.0.0.0
AEGIS_PORT=8000
AEGIS_LOG_LEVEL=INFO
AEGIS_SCAN_ENGINE=nmap
AEGIS_ALLOWED_TARGET_MODE=private
AEGIS_MAX_SCAN_HOSTS=16
AEGIS_NMAP_PATH=
AEGIS_NMAP_HOST_TIMEOUT_SECONDS=120
AEGIS_NMAP_SCRIPT_TIMEOUT_SECONDS=20
AEGIS_NMAP_STATS_INTERVAL_SECONDS=5
AEGIS_ENABLE_OS_DETECTION=false
AEGIS_ENABLE_VULN_SCRIPTS=false
AEGIS_NMAP_VULN_SCRIPT_SELECTOR=vuln
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000,http://127.0.0.1:3000
AEGIS_LOCAL_HOSTNAMES=localhost,host.docker.internal
